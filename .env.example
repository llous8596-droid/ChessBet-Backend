# Copie ce fichier en ".env" et remplis les valeurs

PORT=3000
NODE_ENV=production

# Ton URL frontend (Netlify ou ton domaine)
FRONTEND_URL=https://ton-site.netlify.app

# Supabase → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:TON_MOT_DE_PASSE@db.XXXX.supabase.co:5432/postgres

# Génère une clé aléatoire : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=mets_une_longue_chaine_aleatoire_ici

# Stripe → dashboard.stripe.com → Développeurs → Clés API
STRIPE_SECRET_KEY=sk_test_XXXX

# Stripe → Développeurs → Webhooks → ton endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_XXXX
